// Prisma schema - add models here
generator client {
  provider = "prisma-client"
  output   = "./generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String?
  calorieTarget Int?
  proteinTarget Int?
  carbsTarget   Int?
  fatTarget     Int?
  dailyLogs     DailyLog[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime   @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Food {
  id              String          @id @default(cuid())
  name            String
  brand           String?
  barcode         String?         @unique
  caloriesPerGram Int
  proteinPerGram  Int
  carbsPerGram     Int
  fatPerGram      Int
  source          String
  dailyLogEntries DailyLogEntry[]
  createdAt       DateTime        @default(now())
}

model DailyLog {
  id      String           @id @default(cuid())
  userId  String
  date    DateTime
  entries DailyLogEntry[]
  user    User             @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model DailyLogEntry {
  id               String   @id @default(cuid())
  dailyLogId       String
  foodId           String?
  grams            Int
  caloriesSnapshot Int
  proteinSnapshot  Int
  carbsSnapshot    Int
  fatSnapshot      Int
  dailyLog         DailyLog @relation(fields: [dailyLogId], references: [id])
  food             Food?    @relation(fields: [foodId], references: [id])
}
